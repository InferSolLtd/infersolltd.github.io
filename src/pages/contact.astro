---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Get in touch"
    subtitle="Whether you have a project in mind, need expert advice, or just want to discuss a potential collaboration — we'd love to hear from you."
  />

  <Features2
    title="Reach us directly"
    columns={3}
    items={[
      {
        title: 'Email',
        description: '<a href="mailto:infersol.coms@gmail.com" class="underline">infersol.coms@gmail.com</a>',
        icon: 'tabler:mail',
      },
      {
        title: 'LinkedIn',
        description: '<a href="https://www.linkedin.com/company/infersol-ltd/about/" target="_blank" class="underline">InferSol Ltd</a>',
        icon: 'tabler:brand-linkedin',
      },
      {
        title: 'Location',
        description: 'Cambridge, UK',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <div class="max-w-3xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold text-center mb-6 dark:text-white">Contact form</h2>
    <iframe
      src="https://docs.google.com/forms/d/e/1FAIpQLScy9hW9KxVVg2IUlW56VE_BJlU7Rdevyq-p4qleD91bmlOssQ/viewform?embedded=true"
      width="100%"
      height="600"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
    >
      Loading…
    </iframe>
  </div>
</Layout>
